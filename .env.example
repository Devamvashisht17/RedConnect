# ─────────────────────────────────────────────────────────
#  .env.example — Copy this to .env and fill in your values
#  NEVER commit your actual .env file to Git
# ─────────────────────────────────────────────────────────

# Node environment (set to "production" on Render)
NODE_ENV=development

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.mongodb.net/blooddonation

# JWT secret — use a long random string (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# Session secret — use a different long random string
SESSION_SECRET=your_super_secret_session_key_here

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Callback URL — use localhost for dev, Render URL for production
# Dev:        http://localhost:3000/auth/google/callback
# Production: https://your-app-name.onrender.com/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
