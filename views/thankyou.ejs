<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thank You - RedConnect</title>
  <link rel="stylesheet" href="/css/register.css">
</head>
<body class="thankyou-body">
  <div class="thankyou-container">
    <div class="success-icon">✓</div>
    <h1>Thank You, <%= donorName %>!</h1>
    <p>Your registration as a blood donor has been successfully completed.</p>
    <p>You are now part of our life-saving community. We will contact you when your blood type is needed.</p>
    <div class="action-buttons">
      <a href="/" class="btn-home">Go to Home</a>
      <a href="/register" class="btn-register">Register Another Donor</a>
    </div>
  </div>
</body>
</html>
