<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Page Not Found - 🩸RedConnect</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .error-container {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #e74c3c, #c0392b);
      padding: 20px;
    }
    .error-card {
      background: white;
      padding: 60px 40px;
      border-radius: 15px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
      text-align: center;
      max-width: 500px;
    }
    .error-icon {
      font-size: 80px;
      margin-bottom: 20px;
    }
    .error-title {
      font-size: 2.5rem;
      color: #e74c3c;
      margin-bottom: 15px;
      font-weight: bold;
    }
    .error-message {
      font-size: 1.2rem;
      color: #666;
      margin-bottom: 30px;
      line-height: 1.6;
    }
    .home-btn {
      background: #e74c3c;
      color: white;
      border: none;
      padding: 15px 40px;
      font-size: 16px;
      font-weight: bold;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s;
      text-decoration: none;
      display: inline-block;
    }
    .home-btn:hover {
      background: #c0392b;
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(231, 76, 60, 0.4);
    }
  </style>
</head>
<body>
  <div class="error-container">
    <div class="error-card">
      <div class="error-icon">⚠️</div>
      <h1 class="error-title">404 - Page Not Found</h1>
      <p class="error-message">You have opened wrong page. The page you are looking for does not exist.</p>
      <a href="/" class="home-btn">Go Back to Home</a>
    </div>
  </div>
</body>
</html>