<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <title>RedConnect</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🩸</text></svg>">

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/donation-process.css">
  <link rel="stylesheet" href="/css/volunteers.css">
  <link rel="stylesheet" href="/css/footer.css">
</head>
<body>
  <nav class="navbar">
    <div class="logo">
      <span class="logo-text">🩸RedConnect</span>
    </div>
    <ul class="nav-menu">
      <li><a href="#">ABOUT US</a></li>
      <li><a href="#">ORGANIZE A CAMPAIGN</a></li>
      <li><a href="#">SPREAD AWARENESS</a></li>
      <li><a href="#">JOIN US</a></li>
    </ul>
    <div class="nav-buttons">
      <% if (typeof user !== 'undefined' && user) { %>
        <div class="user-profile">
          <div class="avatar" onclick="toggleDropdown()">
            <%= user.name.charAt(0).toUpperCase() %>
          </div>
          <div class="user-info" onclick="toggleDropdown()">
            <span class="user-name"><%= user.name %></span>
            <span class="user-role"><%= user.activity %></span>
          </div>
          <div class="dropdown-menu" id="dropdownMenu">
            <a href="/logout">Logout</a>
          </div>
        </div>
      <% } else { %>
        <a href="/login"><button class="appointment-btn">LOGIN</button></a><a href="/signup"><button class="appointment-btn">SIGN UP</button></a>
      <% } %>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-content">
      <h1>DONATE BLOOD AND GET REAL BLESSINGS.</h1>
      <p>Blood is the most precious gift that anyone can give to another person.<br>
      Donating blood not only saves the life also save donor's lives.</p>
      <button class="appointment-btn" onclick="window.location.href='/register'">DONATE BLOOD</button>
      <button class="appointment-btn" onclick="window.location.href='/request'">REQUEST BLOOD</button>

    </div>
  </section>

  <%- include('donation-process') %>

  <%- include('volunteers') %>

  <section class="volunteer-section">
    <div class="volunteer-content">
      <h2>JOIN WITH US AND SAVE LIFE</h2>
      <a href="/volunteer" class="volunteer-btn">BECOME VOLUNTEER</a>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script>
    function toggleDropdown() {
      const dropdown = document.getElementById('dropdownMenu');
      dropdown.classList.toggle('show');
    }

    window.onclick = function(event) {
      if (!event.target.matches('.avatar') && !event.target.matches('.user-info') && !event.target.matches('.user-name') && !event.target.matches('.user-role')) {
        const dropdown = document.getElementById('dropdownMenu');
        if (dropdown && dropdown.classList.contains('show')) {
          dropdown.classList.remove('show');
        }
      }
    }
  </script>
</body>
</html>
