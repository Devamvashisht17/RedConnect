<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <title>RedConnect</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🩸</text></svg>">

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/donation-process.css">
  <link rel="stylesheet" href="/css/volunteers.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/donors-group.css">
</head>
<body>
  <%- include('partials/header') %>

  <section class="hero">
    <div class="hero-content">
      <h1>DONATE BLOOD AND GET REAL BLESSINGS.</h1>
      <p>Blood is the most precious gift that anyone can give to another person.<br>
      Donating blood not only saves the life also save donor's lives.</p>
      <button class="appointment-btn" onclick="window.location.href='/register'">DONATE BLOOD</button>
      <button class="appointment-btn" onclick="window.location.href='/request'">REQUEST BLOOD</button>

    </div>
  </section>

  <%- include('donation-process') %>

  <!-- FIND DONORS SECTION -->
  <section class="find-donors-section">
    <div class="find-donors-header">
      <h2>Find Donors by Blood Group</h2>
      <p>Discover available donors for each blood type in your area</p>
    </div>
    <div class="donors-grid">
      <% const cardColors = {'O+':'#e53935','A+':'#8e24aa','B+':'#1e88e5','AB+':'#00897b','O-':'#f4511e','A-':'#6d4c41','B-':'#3949ab','AB-':'#00acc1'}; %>
      <% bloodGroups.forEach(group => { %>
        <a href="/donors/<%= encodeURIComponent(group) %>" class="donor-card">
          <div class="donor-badge" style="background:<%= cardColors[group] %>">
            <%= group %>
          </div>
          <h3><%= group %> Blood Group</h3>
          <p class="donor-count"><%= counts[group] || 0 %> donors available</p>
          <span class="find-btn">Find Donors →</span>
        </a>
      <% }) %>
    </div>
    <div class="compat-guide-btn">
      <a href="/blood" class="compat-btn">Blood Compatibility Guide</a>
    </div>
  </section>

  <%- include('volunteers') %>

  <section class="volunteer-section">
    <div class="volunteer-content">
      <h2>JOIN WITH US AND SAVE LIFE</h2>
      <a href="/volunteer" class="volunteer-btn">BECOME VOLUNTEER</a>
    </div>
  </section>

  <%- include('partials/footer') %>

</body>
</html>
